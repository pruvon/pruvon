{
  "services": [
    {
      "type": "app",
      "data": {
        "name": "rails-app",
        "image": "rails:7.0",
        "env": [
          "RAILS_ENV=production",
          "RAILS_SERVE_STATIC_FILES=true",
          "DATABASE_URL=postgres://postgres:postgres@rails-app-postgres:5432/rails_app_production"
        ],
        "services": [
          {
            "name": "postgres",
            "version": "14"
          },
          {
            "name": "redis",
            "version": "7"
          }
        ],
        "domains": [
          "rails-app.example.com"
        ],
        "ssl": true,
        "ports": [
          "http:80:3000"
        ],
        "mounts": [
          {
            "type": "volume",
            "name": "storage",
            "mountPath": "/rails-app/storage"
          }
        ]
      }
    }
  ]
}
