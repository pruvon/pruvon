{
  "services": [
    {
      "type": "app",
      "data": {
        "name": "minio",
        "image": "minio/minio:RELEASE.2023-07-21T21-12-44Z",
        "env": [
          "MINIO_ACCESS_KEY=minioadmin",
          "MINIO_SECRET_KEY=minioadmin",
          "MINIO_SERVER_URL=https://minio.example.com"
        ],
        "services": [],
        "domains": [
          "minio.example.com"
        ],
        "ssl": true,
        "ports": [
          "http:80:9000",
          "http:9001:9001"
        ],
        "mounts": [
          {
            "type": "volume",
            "name": "data",
            "mountPath": "/data"
          }
        ],
        "command": "server /data --console-address ':9001'"
      }
    }
  ]
}
